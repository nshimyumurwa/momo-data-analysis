{
  "_meta": {
    "project": "MoMo SMS Data Processing System",
    "team": "Team 2",
    "members": ["Therese Mary Nshimyumurwa", "Aimable Bancunguye", "Eloi Mizero", "Davy Dushimiyimana", "Clive Tanaka Mushipe"],
    "description": "JSON representations of all main database entities, showing how relational data is serialized for API responses",
    "version": "1.0.0"
  },

  "schemas": {

    "transaction_category": {
      "_description": "Represents a single transaction category from the transaction_categories table",
      "_sql_table": "transaction_categories",
      "example": {
        "category_id": 1,
        "category_code": "INCOMING_TRANSFER",
        "category_name": "Incoming Money Transfer",
        "direction": "CREDIT",
        "description": "Money received from another MoMo user",
        "is_active": true,
        "created_at": "2025-01-01T00:00:00Z"
      }
    },

    "user": {
      "_description": "Represents a MoMo registered user (individual, merchant, or agent)",
      "_sql_table": "users",
      "example": {
        "user_id": 1,
        "phone_number": "+250788100001",
        "full_name": "Therese Mary Nshimyumurwa",
        "account_type": "INDIVIDUAL",
        "is_verified": true,
        "created_at": "2025-01-15T08:00:00Z",
        "updated_at": "2025-01-15T08:00:00Z"
      }
    },

    "tag": {
      "_description": "A label that can be applied to transactions",
      "_sql_table": "tags",
      "example": {
        "tag_id": 3,
        "tag_name": "high_value",
        "created_at": "2025-01-01T00:00:00Z"
      }
    },

    "system_log": {
      "_description": "A single ETL pipeline audit log entry from system_logs",
      "_sql_table": "system_logs",
      "example": {
        "log_id": 5,
        "log_level": "WARNING",
        "event_type": "AMOUNT_ANOMALY",
        "transaction_id": 7,
        "message": "Amount 250000 exceeds high-value threshold of 200000",
        "source_file": "etl/clean_normalize.py",
        "ip_address": "10.0.0.1",
        "created_at": "2025-05-07T11:00:05Z"
      }
    },

    "transaction_simple": {
      "_description": "Flat transaction record as stored in the transactions table",
      "_sql_table": "transactions",
      "example": {
        "transaction_id": 7,
        "external_ref": "TXN20250507001",
        "category_id": 9,
        "sender_id": null,
        "receiver_id": 3,
        "amount": 250000.00,
        "fee": 0.00,
        "balance_after": 450000.00,
        "currency": "RWF",
        "transaction_date": "2025-05-07T11:00:00Z",
        "status": "SUCCESS",
        "sms_raw_body": "International remittance of 250,000 RWF received. Balance: 450,000 RWF. TxnID:TXN20250507001",
        "parsed_at": "2025-05-07T11:00:02Z",
        "notes": "Manually reviewed and confirmed"
      }
    },

    "transaction_full": {
      "_description": "Complete transaction object with all related data. This is what the API returns when someone requests the full details of one transaction.",
      "_sql_mapping": {
        "transaction_id": "transactions.transaction_id",
        "external_ref": "transactions.external_ref",
        "amount": "transactions.amount",
        "fee": "transactions.fee",
        "balance_after": "transactions.balance_after",
        "currency": "transactions.currency",
        "transaction_date": "transactions.transaction_date",
        "status": "transactions.status",
        "sms_raw_body": "transactions.sms_raw_body",
        "parsed_at": "transactions.parsed_at",
        "notes": "transactions.notes",
        "category": "JOIN transaction_categories ON transactions.category_id",
        "sender": "LEFT JOIN users AS sender ON transactions.sender_id",
        "receiver": "LEFT JOIN users AS receiver ON transactions.receiver_id",
        "tags": "JOIN transaction_tags and tags to resolve the many-to-many relationship",
        "logs": "LEFT JOIN system_logs ON transactions.transaction_id"
      },
      "example": {
        "transaction_id": 7,
        "external_ref": "TXN20250507001",
        "amount": 250000.00,
        "fee": 0.00,
        "balance_after": 450000.00,
        "currency": "RWF",
        "transaction_date": "2025-05-07T11:00:00Z",
        "status": "SUCCESS",
        "sms_raw_body": "International remittance of 250,000 RWF received. Balance: 450,000 RWF. TxnID:TXN20250507001",
        "parsed_at": "2025-05-07T11:00:02Z",
        "notes": "Manually reviewed and confirmed",

        "category": {
          "category_id": 9,
          "category_code": "INTERNATIONAL_IN",
          "category_name": "International Remittance In",
          "direction": "CREDIT"
        },

        "sender": null,

        "receiver": {
          "user_id": 3,
          "phone_number": "+250788100003",
          "full_name": "Eloi Mizero",
          "account_type": "INDIVIDUAL",
          "is_verified": true
        },

        "tags": [
          {
            "tag_id": 3,
            "tag_name": "high_value",
            "tagged_at": "2025-05-07T11:00:03Z",
            "tagged_by": "system"
          },
          {
            "tag_id": 5,
            "tag_name": "international",
            "tagged_at": "2025-05-07T11:00:03Z",
            "tagged_by": "system"
          }
        ],

        "logs": [
          {
            "log_id": 5,
            "log_level": "WARNING",
            "event_type": "AMOUNT_ANOMALY",
            "message": "Amount 250000 exceeds high-value threshold of 200000",
            "source_file": "etl/clean_normalize.py",
            "created_at": "2025-05-07T11:00:05Z"
          }
        ]
      }
    },

    "api_response_list": {
      "_description": "Paginated list response for GET /api/transactions",
      "example": {
        "status": "success",
        "data": {
          "transactions": [
            {
              "transaction_id": 7,
              "external_ref": "TXN20250507001",
              "category_name": "International Remittance In",
              "direction": "CREDIT",
              "receiver": "Eloi Mizero",
              "amount": 250000.00,
              "currency": "RWF",
              "transaction_date": "2025-05-07T11:00:00Z",
              "status": "SUCCESS"
            },
            {
              "transaction_id": 6,
              "external_ref": "TXN20250506001",
              "category_name": "Utility Bill Payment",
              "direction": "DEBIT",
              "sender": "Therese Mary Nshimyumurwa",
              "amount": 15000.00,
              "currency": "RWF",
              "transaction_date": "2025-05-06T07:45:00Z",
              "status": "SUCCESS"
            }
          ],
          "pagination": {
            "page": 1,
            "page_size": 20,
            "total_records": 8,
            "total_pages": 1
          }
        },
        "meta": {
          "generated_at": "2025-05-17T10:00:00Z",
          "version": "1.0"
        }
      }
    },

    "dashboard_summary": {
      "_description": "Aggregated summary object for the dashboard, based on the v_daily_summary view",
      "example": {
        "period": {
          "from": "2025-05-01",
          "to": "2025-05-08"
        },
        "totals": {
          "total_transactions": 8,
          "successful": 7,
          "failed": 1,
          "total_volume_rwf": 480000.00,
          "total_fees_rwf": 400.00
        },
        "by_direction": {
          "credit": {
            "count": 4,
            "volume": 400000.00
          },
          "debit": {
            "count": 4,
            "volume": 80000.00
          }
        },
        "top_categories": [
          { "category_name": "International Remittance In", "count": 1, "volume": 250000.00 },
          { "category_name": "Cash In via Agent",           "count": 1, "volume": 100000.00 },
          { "category_name": "Incoming Money Transfer",     "count": 1, "volume": 50000.00 }
        ]
      }
    }
  }
}
